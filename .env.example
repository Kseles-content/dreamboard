# =========================
# DreamBoard environment
# =========================

# App runtime
NODE_ENV=development
PORT=3000

# Backend database
# Supports postgres://, postgresql:// and prisma+postgres://
DB_PORT=5433
DATABASE_URL=postgresql://dreamboard:change_me@localhost:5433/dreamboard
# Optional SQLite path (used only by local helper scripts if enabled)
DB_PATH=./dreamboard.sqlite

# Auth
JWT_SECRET=change_me_min_8_chars

# Object storage (S3 / MinIO-compatible)
S3_BUCKET=dreamboard-assets
S3_REGION=us-east-1
S3_ENDPOINT=https://s3.example.com
S3_ACCESS_KEY_ID=change_me
S3_SECRET_ACCESS_KEY=change_me

# Public/upload URLs used in generated links
STORAGE_UPLOAD_BASE_URL=https://uploads.example.com
STORAGE_PUBLIC_BASE_URL=https://cdn.example.com
PUBLIC_WEB_BASE_URL=http://localhost:3100

# Frontend (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
